[
  {
    "name": "users",
    "type": "auth",
    "schema": [
      {
        "name": "name",
        "type": "text",
        "required": true,
        "options": { "min": 1, "max": 255 }
      },
      {
        "name": "username",
        "type": "text",
        "required": true,
        "unique": true,
        "options": { "min": 3, "max": 50, "pattern": "^[a-zA-Z0-9._]+$" }
      },
      {
        "name": "bio",
        "type": "text",
        "options": { "max": 500 }
      },
      {
        "name": "avatar",
        "type": "file",
        "options": { "maxSelect": 1, "maxSize": 5242880, "mimeTypes": ["image/jpeg", "image/png", "image/gif", "image/webp"] }
      },
      {
        "name": "banner",
        "type": "file",
        "options": { "maxSelect": 1, "maxSize": 10485760, "mimeTypes": ["image/jpeg", "image/png", "image/gif", "image/webp"] }
      },
      {
        "name": "whatsapp",
        "type": "text",
        "options": { "max": 20 }
      },
      {
        "name": "instagram",
        "type": "url"
      },
      {
        "name": "tiktok",
        "type": "url"
      },
      {
        "name": "twitter",
        "type": "url"
      },
      {
        "name": "youtube",
        "type": "url"
      },
      {
        "name": "telegram",
        "type": "text",
        "options": { "max": 100 }
      },
      {
        "name": "role",
        "type": "select",
        "required": true,
        "options": { "values": ["admin", "creator"] }
      },
      {
        "name": "checkout_fields",
        "type": "json",
        "options": {}
      },
      {
        "name": "theme_settings",
        "type": "json",
        "options": {}
      }
    ],
    "listRule": "",
    "viewRule": "",
    "createRule": "",
    "updateRule": "@request.auth.id = id",
    "deleteRule": "@request.auth.id = id && role != \"admin\"",
    "options": {
      "minPasswordLength": 8,
      "allowEmailAuth": true,
      "allowOAuth2Auth": true,
      "allowUsernameAuth": false
    }
  },
  {
    "name": "products",
    "type": "base",
    "schema": [
      {
        "name": "creator_id",
        "type": "relation",
        "required": true,
        "options": { "collectionId": "users", "cascadeDelete": true, "maxSelect": 1 }
      },
      {
        "name": "title",
        "type": "text",
        "required": true,
        "options": { "min": 1, "max": 255 }
      },
      {
        "name": "slug",
        "type": "text",
        "required": true,
        "options": { "min": 1, "max": 255, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
      },
      {
        "name": "description",
        "type": "text",
        "options": { "max": 2000 }
      },
      {
        "name": "price",
        "type": "number",
        "required": true,
        "options": { "min": 0 }
      },
      {
        "name": "original_price",
        "type": "number",
        "options": { "min": 0 }
      },
      {
        "name": "thumbnail",
        "type": "file",
        "options": { "maxSelect": 1, "maxSize": 5242880, "mimeTypes": ["image/jpeg", "image/png", "image/gif", "image/webp"] }
      },
      {
        "name": "images",
        "type": "file",
        "options": { "maxSelect": 10, "maxSize": 5242880, "mimeTypes": ["image/jpeg", "image/png", "image/gif", "image/webp"] }
      },
      {
        "name": "file_url",
        "type": "url"
      },
      {
        "name": "product_type",
        "type": "select",
        "required": true,
        "options": { "values": ["digital", "physical", "service", "course", "ebook", "preset", "template"] }
      },
      {
        "name": "stock",
        "type": "number",
        "options": { "min": 0 }
      },
      {
        "name": "is_featured",
        "type": "bool"
      },
      {
        "name": "order_count",
        "type": "number",
        "options": { "min": 0 }
      }
    ],
    "listRule": "",
    "viewRule": "",
    "createRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "updateRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "deleteRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "options": {}
  },
  {
    "name": "links",
    "type": "base",
    "schema": [
      {
        "name": "creator_id",
        "type": "relation",
        "required": true,
        "options": { "collectionId": "users", "cascadeDelete": true, "maxSelect": 1 }
      },
      {
        "name": "title",
        "type": "text",
        "required": true,
        "options": { "min": 1, "max": 100 }
      },
      {
        "name": "url",
        "type": "url",
        "required": true
      },
      {
        "name": "icon",
        "type": "text",
        "options": { "max": 50 }
      },
      {
        "name": "order",
        "type": "number",
        "options": { "min": 0 }
      },
      {
        "name": "is_active",
        "type": "bool"
      }
    ],
    "listRule": "",
    "viewRule": "",
    "createRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "updateRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "deleteRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "options": {}
  },
  {
    "name": "orders",
    "type": "base",
    "schema": [
      {
        "name": "creator_id",
        "type": "relation",
        "required": true,
        "options": { "collectionId": "users", "cascadeDelete": false, "maxSelect": 1 }
      },
      {
        "name": "product_id",
        "type": "relation",
        "required": true,
        "options": { "collectionId": "products", "cascadeDelete": false, "maxSelect": 1 }
      },
      {
        "name": "buyer_name",
        "type": "text",
        "required": true,
        "options": { "max": 255 }
      },
      {
        "name": "custom_fields",
        "type": "json",
        "options": {}
      },
      {
        "name": "price",
        "type": "number",
        "required": true,
        "options": { "min": 0 }
      },
      {
        "name": "note",
        "type": "text",
        "options": { "max": 500 }
      },
      {
        "name": "status",
        "type": "select",
        "required": true,
        "options": { "values": ["pending", "paid", "delivered", "completed", "cancelled", "refunded"] }
      }
    ],
    "listRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "viewRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "createRule": "",
    "updateRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "deleteRule": "@request.auth.id != \"\" && creator_id = @request.auth.id",
    "options": {}
  }
]
